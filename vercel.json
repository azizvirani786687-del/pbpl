{
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "^/$", "dest": "/view.html" },
    { "src": "^/view$", "dest": "/view.html" },
    { "src": "^/view/(.*)", "dest": "/view.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
